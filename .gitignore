# ============================================================
# .gitignore for vscode-browser-test
# Documentation-only repository. Most ignores are defensive.
# ============================================================

# ----- OS junk -----
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
*~
.fuse_hidden*

# ----- Editor / IDE -----
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
# JetBrains
.idea/
*.iml
*.iws
*.ipr
# Sublime / Atom / Vim / Emacs
*.sublime-project
*.sublime-workspace
.project
.settings/
.classpath
*~
\#*\#
.\#*

# ----- Node (defensive — should never be needed) -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----- Build / test artifacts (defensive) -----
dist/
build/
out/
coverage/
*.log
*.tsbuildinfo

# ----- Local-only Claude / agent scratch -----
# Don't commit one-off agent-generated files
.claude/.scratch/
.claude/local-*

# ----- Secrets (defensive — never commit) -----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
